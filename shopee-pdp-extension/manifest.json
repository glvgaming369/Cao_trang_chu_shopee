{
  "manifest_version": 3,
  "name": "Shopee PDP → VideoAI Pusher",
  "version": "1.0.0",
  "description": "Cào dữ liệu sản phẩm Shopee (API get_pc) và đẩy lên VideoAI. Báo Telegram khi gặp captcha.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "https://shopee.vn/*",
    "https://shopee.sg/*",
    "https://shopee.ph/*",
    "https://videoai-api.devappnow.com/*",
    "https://api.telegram.org/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Shopee PDP → VideoAI"
  },
  "content_scripts": [
    {
      "matches": ["https://shopee.vn/*", "https://shopee.sg/*", "https://shopee.ph/*"],
      "js": ["content/pageHook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://shopee.vn/*", "https://shopee.sg/*", "https://shopee.ph/*"],
      "js": ["content/bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
